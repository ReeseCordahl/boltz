#  Run Boltz on all 50 .yaml files:
for y in inputs/yaml_affinity_fixed/oapt1b1_*.yaml; do
    name=$(basename "$y" .yaml)
    echo "Running $name..."
    boltz predict "$y" --out_dir "outputs_affinity_fixed/$name" --use_msa_server
done

